PREFIX=!
DISCORD_TOKEN=your-bot-token-here
APPLICATION_ID=your-application-id
GUILD_ID=your-test-guild-id
BIRTHDAY_CHANNEL_ID=your-channel-id-for-birthday-announcements
ANNIVERSARY_CHANNEL_ID=your-channel-id-for-guild-anniversary-announcements
ANNIVERSARY_TIME=18:00
GENERAL_CHANNEL_ID=your-general-channel-id
COMMAND_LOG_CHANNEL_ID=your-command-log-channel-id
DEV_REGISTER=false
NEWSLETTER_CHANNEL_ID=1303788137876684931

# Admin panel · only needed to expose it beyond localhost via Cloudflare Tunnel
ADMIN_PORT=3001
ADMIN_PUBLIC_HOST=admin.meerbot.dev
ADMIN_OAUTH_REDIRECT=https://admin.meerbot.dev/auth/callback
# Client ID = your Application ID · falls back to APPLICATION_ID, so usually leave unset
# DISCORD_CLIENT_ID=
# Client Secret is SEPARATE from the bot token · OAuth2 page -> Reset Secret (safe, does not touch the bot token)
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
SESSION_SECRET=generate-a-long-random-string
# ADMIN_INSECURE_COOKIE=true   # set ONLY for local http login testing, never in prod